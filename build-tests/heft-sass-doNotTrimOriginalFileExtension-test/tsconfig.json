{
  "$schema": "http://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "outDir": "lib-commonjs",
    "rootDir": "src",
    "rootDirs": ["src", "temp/sass-ts"],

    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "inlineSources": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "types": ["heft-jest", "node"],

    "module": "commonjs",
    "target": "es2017",
    "lib": ["es2017"]
  },
  "include": ["src/**/*.ts"]
}
